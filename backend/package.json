    "firebase-admin": "^13.10.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.3",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0"
  },
  "optionalDependencies": {
    "@sentry/node": "^8.55.0"
