# Daily Rashan API — copy to .env.development | .env.staging | .env.production
NODE_ENV=development
APP_NAME=DailyRashan
API_PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Database (use connection pooling in production via PgBouncer or ?connection_limit=)
DATABASE_URL=postgresql://rashan:rashan_secret@localhost:5432/daily_rashan?schema=public

# JWT — min 32 characters in production
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Redis (optional in dev; recommended in staging/production)
REDIS_URL=redis://localhost:6379

# OTP
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin (FCM) — escape newlines in private key as \n
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Cache TTL (seconds)
CACHE_TTL_HOME=120
CACHE_TTL_DASHBOARD=60
CACHE_TTL_PRODUCTS=180

# Monitoring (optional)
SENTRY_DSN=
LOG_LEVEL=info

# Payment
PAYMENT_TIMEOUT_MINUTES=30
