# Dhrigro API — environment variables
# Copy to .env.development | .env.staging | .env.production

# --- App ---
NODE_ENV=development
APP_NAME=Dhrigro
APP_VERSION=0.0.1
APP_URL=https://dhrigro.com
ADMIN_URL=https://admin.dhrigro.com
API_URL=https://api.dhrigro.com/api/v1

# --- Server ---
# Railway injects PORT; API_PORT is a local fallback.
PORT=3000
API_PORT=3000
API_PREFIX=api/v1

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:8080,http://localhost:8081,http://127.0.0.1:8080,http://127.0.0.1:8081,https://dhrigro.com,https://www.dhrigro.com,https://admin.dhrigro.com

# --- Database ---
DATABASE_URL=postgresql://rashan:rashan_secret@localhost:5432/daily_rashan?schema=public

# --- JWT (min 32 characters in production) ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Redis (optional in dev) ---
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

# --- Rate limiting ---
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
# Legacy aliases (still supported):
# THROTTLE_TTL=60
# THROTTLE_LIMIT=100

# --- OTP ---
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Firebase Admin (FCM) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Cache TTL (seconds) ---
CACHE_TTL_HOME=120
CACHE_TTL_DASHBOARD=60
CACHE_TTL_PRODUCTS=180

# --- Feature flags ---
REALTIME_ENABLED=true
QUEUES_ENABLED=true
SWAGGER_ENABLED=false

# --- Monitoring ---
SENTRY_DSN=
LOG_LEVEL=info
METRICS_ENABLED=true
METRICS_TOKEN=

# --- Payments ---
PAYMENT_TIMEOUT_MINUTES=30
