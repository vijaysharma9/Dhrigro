# ===========================================
# Daily Rashan - Environment Configuration
# ===========================================

# App
APP_NAME=DailyRashan
NODE_ENV=development
API_PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# Database
DATABASE_URL=postgresql://rashan:rashan_secret@localhost:5432/daily_rashan?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OTP (dev: logs to console; prod: Twilio/MSG91)
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Stripe (ready)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=daily-rashan-uploads

# Cloudinary (product & banner images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin (FCM)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@dhrigro.com

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Flutter apps
FLUTTER_API_BASE_URL=http://localhost:3000/api/v1
